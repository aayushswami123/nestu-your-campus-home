# Supabase — use the SERVICE ROLE key (Project Settings → API → service_role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Keep this secret — server-side only

# AutoSend (transactional email)
AUTOSEND_API_KEY=your-autosend-api-key
FROM_EMAIL=hello@nestu.app

# Frontend URL — used for CORS and email links
FRONTEND_URL=https://nestu.app

# Port — Render injects this automatically; 3001 for local dev
PORT=3001
